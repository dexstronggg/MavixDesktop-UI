# --- Server ---
# Base URL of the MavixServer HTTP API; WebSocket URL is derived from
# this (http -> ws, https -> wss, path /ws/gcs).
SIGNAL_URL=https://drone-mavix.ru

# --- WebRTC ICE (override) ---
# Leave empty (default) to use whatever the server returns via
# /api/v1/ice-servers. Set all four to force specific STUN/TURN instead.
STUN_SERVER=
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# --- QGC / MAVLink relay ---
# When the FC is MAVLink, packets received on the WebRTC data-channel are
# forwarded to a local UDP socket so QGroundControl (or another MAVLink
# client) can connect to it.
QGC_HOST=127.0.0.1
QGC_PORT=14550
QGC_BIND_PORT=0

# --- Auth ---
# OS keyring service name used to store the user's refresh token across
# launches. Change only if you run multiple instances side by side.
KEYRING_SERVICE=mavixdesktop

# --- Debug ---
# 1/true — start on a debug page with manual-test buttons (e.g. launch
# QGroundControl) so individual features can be checked without a board or
# server; also raises logging to DEBUG. Source-run only: .env is not read
# inside the PyInstaller bundle.
DEBUG=0
